# ============================================================
# Personal Finance Dashboard — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is in .gitignore.
# See CLAUDE.md for which variables are safe client-side.
# ============================================================

# ------ Supabase (safe to expose — RLS enforced) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------ Supabase (SERVER ONLY — bypasses RLS) ------
# Never prefix with NEXT_PUBLIC_. Never import in client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ Supabase (direct DB connection for MCP / migrations) ------
# Used by the Supabase MCP server and CLI only — not in app code
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ------ OpenAI (SERVER ONLY) ------
# Never prefix with NEXT_PUBLIC_. Only used in API routes.
OPENAI_API_KEY=sk-your-openai-key-here

# ------ Resend email (Edge Functions only) ------
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ------ GitHub (Claude Code MCP only — not used in app) ------
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token-here
