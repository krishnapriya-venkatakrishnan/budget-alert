#!/bin/sh
# Runs before every commit — blocks if type check or lint fails

echo "Running pre-commit checks..."

npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "TypeScript check failed. Fix errors before committing."
  exit 1
fi

npx eslint . --max-warnings 0
if [ $? -ne 0 ]; then
  echo "ESLint failed. Fix lint errors before committing."
  exit 1
fi

echo "Pre-commit checks passed."
