{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(tsc *)",
      "Bash(node *)",
      "Bash(chmod +x *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(npm audit *)",
      "Bash(gitleaks *)",
      "Bash(supabase *)",
      "Bash(vercel *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.development)",
      "Read(./.env.test)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.local)",
      "Write(./.env.production)",
      "Write(./.env.development)",
      "Write(./.env.test)",
      "Edit(./.env)",
      "Edit(./.env.local)",
      "Edit(./.env.production)",
      "Edit(./.env.development)",
      "Edit(./.env.test)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(rm -rf *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-sensitive-files.sh"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-on-save.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[now | todate, .tool_input.command] | @tsv' >> \"$CLAUDE_PROJECT_DIR\"/.claude/bash-history.log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context restored after compaction. Project: Personal Finance Dashboard. Stack: Next.js 14 + TypeScript + Supabase + OpenAI GPT-4o-mini + Vercel. Key rules: SUPABASE_SERVICE_ROLE_KEY server-only, OPENAI_API_KEY never NEXT_PUBLIC_, RLS on all tables, CSV parsed server-side only. Run pnpm dev to start. See CLAUDE.md for full spec.'"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Session started in: $(pwd). Build phase: check CLAUDE.md section 'Build Phases'. Reminder: never commit .env files, always validate Supabase session in API routes.\""
          }
        ]
      }
    ],

    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Budget Alert Project\"' 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-reminder.sh"
          }
        ]
      }
    ]
  }
}
